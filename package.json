{
  "name": "novella",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/server.ts",
    "build": "rimraf dist && tsc && tsc-alias",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "imports": {
    "#config/*.js": "./dist/config/*.js",
    "#utils/*.js": "./dist/utils/*.js",
    "#errors/*.js": "./dist/errors/*.js",
    "#middlewares/*.js": "./dist/middlewares/*.js",
    "#controllers/*.js": "./dist/controllers/*.js",
    "#models/*.js": "./dist/models/*.js",
    "#schemas/*.js": "./dist/schemas/*.js",
    "#dtos/*.js": "./dist/dtos/*.js",
    "#routes/*.js": "./dist/routes/*.js",
    "#types/*.js": "./dist/types/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asim-momin-7864/Novella.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/asim-momin-7864/Novella/issues"
  },
  "homepage": "https://github.com/asim-momin-7864/Novella#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.2",
    "pino": "^10.3.1",
    "pino-correlation-id": "^1.0.0",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
